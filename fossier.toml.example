# Fossier configuration
# Place this file at repo root as `fossier.toml` or `.github/fossier.toml`

[repo]
# owner = "your-org"
# name = "your-repo"
# db_path = ".fossier.db"

[thresholds]
allow_score = 70.0    # Score >= this → auto-allow
deny_score = 40.0     # Score < this → auto-deny
min_confidence = 0.5  # Below this → force REVIEW regardless of score

[weights]
# Signal weights (auto-normalized to sum to 1.0)
account_age = 0.11
public_repos = 0.07
contribution_history = 0.07
open_prs_elsewhere = 0.11
prior_interaction = 0.11
pr_content = 0.11
follower_ratio = 0.07
bot_signals = 0.07
commit_email = 0.05
pr_description = 0.05
repo_stars = 0.05
org_membership = 0.05
commit_verification = 0.08

[actions.deny]
close_pr = true
comment = true
label = "fossier:spam-likely"
# contact_url = "https://discord.gg/your-server"  # Where contributors can appeal

[actions.review]
comment = true
label = "fossier:needs-review"

[actions.allow]
# label = "fossier:verified"  # Label applied to PRs from scored-and-passed contributors
# comment = false              # Post a verification comment on allowed PRs

[cache_ttl]
user_profile_hours = 24
search_hours = 1
collaborators_hours = 6

[trust]
# Additional trusted/blocked users beyond VOUCHED.td and CODEOWNERS
# trusted_users = ["dependabot", "renovate"]
# blocked_users = ["known-spammer"]
# trusted_orgs = ["my-company", "trusted-foundation"]  # Trust all members of these GitHub orgs
# bot_policy = "score"  # "score" (default), "allow", or "block"
# reject_ai_authored = false  # auto-deny PRs with AI co-authored commits (Claude, Copilot, etc.)

[registry]
# Global fossier spam registry: share spam intelligence across repositories
# url = "https://registry.fossier.io"
# api_key = ""                    # Prefer FOSSIER_REGISTRY_API_KEY env var
# report_denials = false          # Report score-based denials to the registry
# check_before_scoring = false    # Block users with 3+ registry reports before scoring
